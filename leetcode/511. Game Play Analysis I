import pandas as pd

def game_analysis(activity: pd.DataFrame) -> pd.DataFrame:
    activity = activity.sort_values(
    by=["player_id", "event_date"],
    ascending=[True, True])
    
    result = activity.groupby("player_id").head(1)

    return result[["player_id", "event_date"]].rename(columns={"event_date" : "first_login"})
