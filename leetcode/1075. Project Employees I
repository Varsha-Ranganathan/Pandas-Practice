import pandas as pd

def project_employees_i(project: pd.DataFrame, employee: pd.DataFrame) -> pd.DataFrame:
    experience_years_employee = pd.merge(project, employee, on="employee_id")
    experience_years_employee["average_years"] = experience_years_employee.groupby(by="project_id").experience_years.transform("mean").round(2)

    return experience_years_employee.loc[:, ["project_id", "average_years"]].drop_duplicates()
    
