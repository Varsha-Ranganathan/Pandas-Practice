import pandas as pd

def find_customers(customers: pd.DataFrame, orders: pd.DataFrame) -> pd.DataFrame:
    customers = customers.rename(columns={"id" : "customerId"})
    customers_orders_details = pd.merge(customers, orders, on="customerId", how="left")
    no_order_customers = customers_orders_details[customers_orders_details.id.isnull()][["name"]]

    return no_order_customers.rename(columns={"name" : "Customers"})
